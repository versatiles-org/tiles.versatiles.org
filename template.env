# tiles.versatiles.org Configuration
# Copy this file to .env and fill in the values

# Domain name
DOMAIN_NAME=tiles.versatiles.org

# RAM disk size for nginx cache (in GB)
RAM_DISK_GB=4

# Email for Let's Encrypt certificate notifications
EMAIL=name@example.org

# Storage box credentials (source of the .versatiles tile data)
# SSH is used for file scanning + download (port 23)
# WebDAV is used as a transitional fallback while files are syncing
STORAGE_URL=??????@??????.de
STORAGE_PASS=
