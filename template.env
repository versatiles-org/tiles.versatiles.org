# tiles.versatiles.org Configuration
# Copy this file to .env and fill in the values

# Domain name
DOMAIN_NAME=tiles.versatiles.org

# RAM disk size for nginx cache (in GB)
RAM_DISK_GB=4

# Email for Let's Encrypt certificate notifications
EMAIL=name@example.org

# Storage box (source of the .versatiles tile data)
# SSH (port 23) is used for file scanning + download, via the key in .ssh/storage
STORAGE_URL=??????@??????.de

# Public download site used as the transitional source while a file is still
# syncing locally (optional; defaults to https://download.versatiles.org)
# DOWNLOAD_BASE_URL=https://download.versatiles.org
