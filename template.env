# tiles.versatiles.org Configuration
# Copy this file to .env and fill in the values

# Domain name
DOMAIN_NAME=tiles.versatiles.org

# RAM disk size for nginx cache (in GB)
RAM_DISK_GB=4

# Email for Let's Encrypt certificate notifications
EMAIL=name@example.org

# CDN that hosts the .versatiles tile data (downloaded with aria2c, and used as
# the transitional source while a file is still syncing locally).
# Optional; defaults to https://download.versatiles.org
# CDN_BASE_URL=https://download.versatiles.org

# Directory holding the downloaded .versatiles tile data — by far the largest
# volume (hundreds of GB). Point this at another filesystem / mount if the
# default location is too small. May be an absolute path. The directory is
# created and chowned to 1001:1001 by bin/deploy/ensure.sh.
# Optional; defaults to ./volumes/tiles
# TILES_DIR=/mnt/bigdisk/tiles
