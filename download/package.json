{
  "name": "download-updater",
  "version": "1.0.0",
  "description": "TypeScript pipeline for download.versatiles.org",
  "type": "module",
  "private": true,
  "scripts": {
    "build:site": "vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "dev": "tsx src/generate_testdata.ts && vite dev",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint:fix": "eslint src/ --fix",
    "lint": "eslint src/",
    "once": "tsx src/run_once.ts",
    "prepare": "svelte-kit sync",
    "preview:site": "vite preview",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test": "vitest run",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "upgrade": "npm-check-updates -u; rm -r node_modules; rm package-lock.json; npm install"
  },
  "overrides": {
    "cookie": "^0.7.0"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "svelte": "^5.55.5",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "npm-check-updates": "^22.2.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "sass": "^1.99.0",
    "svelte-check": "^4.4.8"
  }
}
