{
  "name": "download-updater",
  "version": "1.0.0",
  "description": "TypeScript pipeline that mirrors .versatiles tile data to local storage and generates versatiles.yaml",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint:fix": "eslint src/ --fix",
    "lint": "eslint src/",
    "once": "tsx src/run_once.ts",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test": "vitest run",
    "upgrade": "npm-check-updates -u; rm -r node_modules; rm package-lock.json; npm install"
  },
  "dependencies": {
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "npm-check-updates": "^22.2.1",
    "prettier": "^3.8.3"
  }
}
